# MongoDB
MONGO_HOST=mongodb
MONGO_USER=root
MONGO_PASS=secret
MONGO_DB=smartbase
MONGO_PORT=27017

# JWT
JWT_SECRET=your_jwt_secret_here

# Build
BUILD_VERSION=202603.01
BUILD_TPYE=development

# MQTT
# Hinweis: Fuer den Standard-Start ist MQTT deaktiviert.
# Um MQTT zu aktivieren, verwende docker-compose-op.yml (enthaelt Mosquitto)
# und setze MQTT_ENABLED=true sowie den passenden Broker.
MQTT_ENABLED=false
MQTT_BROKER=mqtt://mosquitto:1883
